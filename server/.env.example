PORT=8080
MONGO_URI=mongodb://localhost:27017/learnforge

AUTH0_ISSUER=https://YOUR_TENANT.auth0.com/
AUTH0_AUDIENCE=https://learnforge-api

CORS_ALLOWED_ORIGINS=http://localhost:5173

# AI_PROVIDER: gemini (recommended, free key) | openai | template (rule-based, offline)
AI_PROVIDER=gemini
AI_MAX_RETRIES=4
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Get a free key (starts with "AIza...") at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-2.5-flash
YOUTUBE_API_KEY=

APP_NAME=LearnForge API
